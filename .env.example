# ── LLM provider ─────────────────────────────────────────────────────────────
# "anthropic" (default) uses ANTHROPIC_API_KEY below.
# Anything else uses the openai-compatible path: set LLM_BASE_URL + LLM_API_KEY.
LLM_PROVIDER=anthropic

# paid: anthropic
ANTHROPIC_API_KEY=your_key_here

# free option 1: openrouter — free key at openrouter.ai
# LLM_PROVIDER=openrouter
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-your_key_here
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free

# free option 2: groq (fastest free option) — free key at console.groq.com
# LLM_PROVIDER=groq
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_your_key_here
# LLM_MODEL=llama-3.1-8b-instant

# free option 3: ollama (local, no key needed)
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.2

# ── character ─────────────────────────────────────────────────────────────────
CHARACTER_NAME=Tulpa
# Leave blank to use the built-in default persona (recommended to start)
CHARACTER_SYSTEM_PROMPT=

# ── TTS (edge-tts) ────────────────────────────────────────────────────────────
# Run `edge-tts --list-voices` to browse available voices
TTS_VOICE=en-US-AnaNeural
TTS_PITCH=+0Hz
TTS_RATE=-5%
TTS_VOLUME=+0%

# ── VTubeStudio ───────────────────────────────────────────────────────────────
VTUBE_STUDIO_HOST=localhost
VTUBE_STUDIO_PORT=8001
VTS_PLUGIN_NAME=tulpamancer
# Hotkey IDs from VTubeStudio (Settings → Hotkeys → copy the ID)
# Leave blank to skip hotkey triggers
VTS_TALKING_HOTKEY=
VTS_IDLE_HOTKEY=

# ── lip sync ──────────────────────────────────────────────────────────────────
# Set to 0 to disable if your model has no MouthOpen parameter
LIPSYNC_ENABLED=1
LIPSYNC_FPS=24

# ── subtitles (OBS text source) ───────────────────────────────────────────────
# Point an OBS text source (Read from file) at this path
SUBTITLE_PATH=/tmp/tulpamancer_sub.txt

# ── Twitch chat (optional) ────────────────────────────────────────────────────
# Set channel name to enable anonymous read-only chat injection
# No token required — read-only access only
TWITCH_CHANNEL=

# ── loop behavior ─────────────────────────────────────────────────────────────
SPEECH_INTERVAL=2.0
LLM_MODEL=claude-haiku-4-5-20251001
LLM_MAX_TOKENS=150
LLM_MAX_HISTORY=20
